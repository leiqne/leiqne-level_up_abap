managed implementation in class zbp_egui_r_purc_order unique;
strict ( 2 );
with draft;
extensible;


define behavior for ZEGUI_R_PURC_ORDER //alias <alias_name>
persistent table zegui_purc_order
draft table zegui_purc_d
with additional save
lock master total etag OrderDate
late numbering
authorization master ( instance )
//etag master <field_name>
extensible {
  create ( authorization : global );
  update;
  delete;

  draft action Edit;
  draft action Activate optimized;
  draft action Discard;
  draft action Resume;
  draft determine action Prepare;

  field ( readonly) PoId, Summary;
  field ( mandatory: create ) OrderDate, DeliveryDate, BuyerId, Status;
  association _Items {create; with draft; }


  //validations
  validation checkDates on save { field OrderDate, DeliveryDate;  }
  //determinations
  determination SetInitialStatus on modify { create; }
  //actions
  action ( features: instance, authorization: update )ChangeStatus parameter ZEGUI_A_CHANGESTATUS result [1] $self;

    //events
    event orderCreated parameter zegui_a_purc_order;
    //its the same with my timestamp
    side effects { field llm_status affects field Summary;  }


  mapping for zegui_purc_order corresponding extensible {
    PoId=po_id;
    DeliveryDate = deliverydate;
    OrderDate= orderdate;
    Status= status;
    CurrencyCode= currencycode;
    BuyerId      = buyer_id;
  }
}

define behavior for ZEGUI_R_PO_ITEM
    persistent table zegui_po_item
    draft table zegui_poitm_d
    lock dependent by _Header
    late numbering
    authorization dependent by _Header
extensible {
    update;
    delete;
    field (readonly) PoItemId;
    field (readonly) PoId;

    association _Header{with draft;}

    //determinations
    determination SetDefaultCurrencyCode on save { create; }

    mapping for zegui_po_item corresponding extensible{
        PoItemId = po_item_id;
        PoId = po_id;
        Productname = productname;
       Quantity = quantity;
        Currencycode = currencycode;
       Unitprice = unitprice;
    }
}